{
  "name": "@hkyutong/wechat",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw 微信通道插件：通过 Proxy API 接入微信账号",
  "license": "MIT",
  "author": "hkyutong",
  "files": [
    "index.ts",
    "src",
    "openclaw.plugin.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hkyutong/Wechat-Claw.git"
  },
  "bugs": {
    "url": "https://github.com/hkyutong/Wechat-Claw/issues"
  },
  "homepage": "https://github.com/hkyutong/Wechat-Claw#readme",
  "keywords": [
    "openclaw",
    "wechat",
    "微信",
    "gateway",
    "plugin"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "wechat",
      "label": "OpenClaw WeChat",
      "selectionLabel": "OpenClaw WeChat (微信)",
      "docsPath": "/channels/wechat",
      "docsLabel": "wechat",
      "blurb": "OpenClaw 微信通道插件，通过 Proxy API 接入微信账号。",
      "order": 80
    }
  },
  "dependencies": {
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2",
    "@types/node": "^20.10.0",
    "openclaw": ">=2026.3.31",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.31"
  },
  "scripts": {
    "test": "npx tsx test-channel.ts && npx tsx test-plugin.ts && npx tsx test-business.ts && npx tsx test-wechatpadpro.ts && npx tsx test-stability.ts",
    "test:channel": "npx tsx test-channel.ts",
    "test:plugin": "npx tsx test-plugin.ts",
    "test:business": "npx tsx test-business.ts",
    "test:wechatpadpro": "npx tsx test-wechatpadpro.ts",
    "test:stability": "npx tsx test-stability.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test"
  }
}
